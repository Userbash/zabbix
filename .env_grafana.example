VIRTUAL_HOST=10.0.0.13
GF_SERVER_ROOT_URL=http://grafana:3000
ROOT_USER=postgres
ROOT_PASSWORD=postgres
GF_DATABASE_NAME=grafana
GF_DATABASE_USER=grafana
GF_DATABASE_PASSWORD=your_password
GF_DATABASE_TYPE=postgres
GF_DATABASE_HOST=postgres
GF_DATABASE_SSL_MODE=disable
GF_SESSION_PROVIDER=postgres
GF_SESSION_PROVIDER_CONFIG=user=grafana password=your_password host=postgres port=5432 dbname=grafana sslmode=disable
GF_SERVER_ROUTER_LOGGING=true
GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource,alexanderzobnin-zabbix-app
GF_LOG_CONSOLE_FORMAT=json
GF_LOG_FILTERS=alerting.notifier:debug,alerting.notifier.slack:debug,auth:debug
GF_AUTH_TOKEN_ROTATION_INTERVAL_MINUTES=2

